# ============================================================
# Digest Agent - 環境變數配置範本
# ============================================================
# 使用方式：cp .env.example .env，然後填入實際值
# 標示說明：[Required] = 必填  [Optional] = 選填（有預設值）
# Mock 模式：未設定 API Key 或使用 test- 前綴時，自動進入 mock 模式
# ============================================================

# ------------------------------------------------------------
# 1. Gemini AI 摘要服務
# ------------------------------------------------------------

# [Required] Google Gemini API Key（用於文章摘要生成）
# 取得方式：https://aistudio.google.com/app/apikey
# 未設定時自動進入 Mock 模式（回傳模擬摘要）
GEMINI_API_KEY=your-gemini-api-key-here

# [Optional] Gemini API 每分鐘速率限制（預設 14）
GEMINI_RATE_LIMIT_PER_MINUTE=14

# ------------------------------------------------------------
# 2. Email 發佈渠道（SMTP）
# ------------------------------------------------------------

# [Required] SMTP 伺服器地址
SMTP_SERVER=smtp.gmail.com

# [Optional] SMTP 連接埠（預設 587，支援 TLS）
SMTP_PORT=587

# [Required] SMTP 登入帳號（同時作為寄件人地址）
SMTP_USER=your-email@gmail.com

# [Required] SMTP 登入密碼（Gmail 請使用應用程式密碼）
# 取得方式：Google 帳號 → 安全性 → 應用程式密碼
SMTP_PASSWORD=your-app-password-here

# [Optional] 寄件人顯示名稱（預設 "Digest Agent"）
SMTP_FROM_NAME="Digest Agent"

# [Required] 收件人 Email 地址
EMAIL_TO=recipient@example.com

# ------------------------------------------------------------
# 3. Telegram 發佈渠道
# ------------------------------------------------------------

# [Required] Telegram Bot Token
# 取得方式：透過 @BotFather 建立 Bot 取得
TELEGRAM_BOT_TOKEN=your-bot-token-here

# [Required] 目標 Chat ID（個人或群組）
# 取得方式：傳訊息給 Bot 後，呼叫 getUpdates API
TELEGRAM_CHAT_ID=your-chat-id-here

# ------------------------------------------------------------
# 4. LINE 發佈渠道
# ------------------------------------------------------------

# [Required] LINE Channel Access Token
# 取得方式：LINE Developers Console → Messaging API
LINE_CHANNEL_TOKEN=your-line-channel-token-here

# [Required] 目標用戶 ID（push 模式）
LINE_USER_ID=your-line-user-id-here

# ------------------------------------------------------------
# 5. Discord 發佈渠道
# ------------------------------------------------------------

# [Required] Discord Webhook URL
# 取得方式：伺服器設定 → 整合 → Webhook → 新增 Webhook → 複製 URL
DISCORD_WEBHOOK_URL=your-discord-webhook-url-here

# ------------------------------------------------------------
# 6. 應用程式設定
# ------------------------------------------------------------

# [Optional] 資料庫連線 URL
# 本地開發：sqlite:///./data/digest.db（預設）
# Cloud Run：postgresql+psycopg2://postgres.PROJECT:PWD@pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite:///./data/digest.db

# [Optional] 應用程式環境（development / production）
APP_ENV=development

# [Optional] 日誌等級（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# [Optional] Google Cloud Project ID (用於 Cloud Run 部署或環境辨識)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id-here

# [Optional] 時區設定
TIMEZONE=Asia/Taipei
