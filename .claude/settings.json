{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard_rails.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "github": {
      "type": "sse",
      "url": "https://gitmcp.io/jimmyliao/digest-agent"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    }
  }
}
